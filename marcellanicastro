    {grupo:"Recursos Eleitorais",label:"Embargos de Declaração eleitorais (art. 275, §1º, CE)",dias:3,tipo:"corridos"},
    {grupo:"Recursos Eleitorais",label:"Recurso contra propaganda irregular – 24h (art. 96, §8º)",dias:1,tipo:"corridos"},
    {grupo:"Ações Eleitorais",label:"AIJE – prazo de propositura (art. 22, LC 64/90)",dias:15,tipo:"corridos"},
    {grupo:"Ações Eleitorais",label:"AIJE – contestação (art. 3º, LC 64/90)",dias:5,tipo:"corridos"},
    {grupo:"Ações Eleitorais",label:"AIME – propositura após diplomação (art. 14, §10, CF)",dias:15,tipo:"corridos"},
    {grupo:"Ações Eleitorais",label:"AIRC – impugnação de registro (art. 3º, LC 64/90)",dias:5,tipo:"corridos"},
    {grupo:"Ações Eleitorais",label:"Captação ilícita de sufrágio (art. 41-A, Lei 9.504/97)",dias:15,tipo:"corridos"},
    {grupo:"Ações Eleitorais",label:"Personalizado...",dias:null,tipo:"corridos"},
  ],
};

const ramoLabels={civel:"Cível",criminal:"Criminal",trabalhista:"Trabalhista",eleitoral:"Eleitoral"};
const ramoColors={civel:"#b02626",criminal:"#2d3561",trabalhista:"#1a5c38",eleitoral:"#7c4d00"};

function fmt(d){return d.toLocaleDateString("pt-BR",{weekday:"long",day:"2-digit",month:"long",year:"numeric"});}
function toISO(d){return d.toISOString().slice(0,10);}
function addDays(d,n){const r=new Date(d);r.setDate(r.getDate()+n);return r;}
function isFer(d,uf){const iso=toISO(d);return feriadosNacionais.has(iso)||(uf&&feriadosEstaduais[uf]?.has(iso));}
function isUtil(d,uf,rec){if(d.getDay()===0||d.getDay()===6)return false;if(isFer(d,uf))return false;if(rec&&emRecesso(d))return false;return true;}

function calcular(inicio,qtd,tipo,uf,rec){
  if(qtd===0)return{vencimento:inicio,eventos:[]};
  let atual=addDays(inicio,1);const ev=[];
  if(tipo==="corridos"){
    let c=0;
    while(c<qtd){ev.push({data:new Date(atual),feriado:isFer(atual,uf),recesso:rec&&emRecesso(atual),contado:true});c++;if(c<qtd)atual=addDays(atual,1);}
    while(!isUtil(atual,uf,rec)){atual=addDays(atual,1);ev.push({data:new Date(atual),prorrogado:true});}
  }else{
    let c=0;
    while(c<qtd){const u=isUtil(atual,uf,rec);ev.push({data:new Date(atual),util:u,feriado:isFer(atual,uf),recesso:rec&&emRecesso(atual),contado:u?++c:false});if(c<qtd)atual=addDays(atual,1);}
  }
  return{vencimento:atual,eventos:ev};
}
function diasRest(v){const h=new Date();h.setHours(0,0,0,0);const vv=new Date(v);vv.setHours(0,0,0,0);return Math.round((vv-h)/86400000);}

function App(){
  const [modo,setModo]=useState("vencimento");
  const [ramo,setRamo]=useState("civel");
  const [tribunal,setTribunal]=useState(tribunais.civel[0]);
  const [prazo,setPrazo]=useState(prazosConfig.civel[0]);
  const [cDias,setCDias]=useState(15);
  const [cTipo,setCTipo]=useState("uteis");
  const [dAto,setDAto]=useState("");
  const [dVenc,setDVenc]=useState("");
  const [recesso,setRecesso]=useState(true);
  const [res,setRes]=useState(null);
  const [busca,setBusca]=useState("");

  const accent=ramoColors[ramo];
  const lista=busca.trim()?prazosConfig[ramo].filter(p=>p.label.toLowerCase().includes(busca.toLowerCase())||(p.grupo||"").toLowerCase().includes(busca.toLowerCase())):null;

  function mudarRamo(r){setRamo(r);setTribunal(tribunais[r][0]);setPrazo(prazosConfig[r][0]);setRes(null);setBusca("");}

  function calc(){
    const isC=prazo.dias===null;
    const qtd=isC?parseInt(cDias):prazo.dias;
    const tipo=isC?cTipo:prazo.tipo;
    const uf=tribunal.uf;
    if(modo==="vencimento"){
      if(!dAto)return;
      const inicio=new Date(dAto+"T12:00:00");
      const{vencimento,eventos}=calcular(inicio,qtd,tipo,uf,recesso);
      setRes({modo:"vencimento",vencimento,eventos,restam:diasRest(vencimento),qtd,tipoPrazo:tipo});
    }else{
      if(!dVenc)return;
      const v=new Date(dVenc+"T12:00:00");
      setRes({modo:"restante",vencimento:v,restam:diasRest(v)});
    }
  }

  const sc=res?(res.restam<0?"#b02626":res.restam<=3?"#c0392b":res.restam<=7?"#e67e22":"#1a5c38"):"#1a5c38";

  const inp={width:"100%",padding:"10px 12px",borderRadius:6,border:"1.5px solid #ddd",fontSize:14,background:"#fff",color:"#1a1a1a",outline:"none"};
  const card={background:"#fff",borderRadius:10,boxShadow:"0 2px 12px #00000010",border:"1px solid #e8e8e8",padding:"22px",marginBottom:14};

  return(
    <div style={{minHeight:"100vh",background:"#f4f4f4",fontFamily:"'Segoe UI',Arial,sans-serif"}}>

      {/* ── HEADER ── */}
      <div style={{background:"#fff",borderBottom:"3px solid #b02626",boxShadow:"0 2px 8px #00000012"}}>
        <div style={{maxWidth:860,margin:"0 auto",padding:"18px 20px"}}>
          {/* Logo */}
          <div style={{display:"flex",alignItems:"center",gap:20,marginBottom:16,paddingBottom:16,borderBottom:"1px solid #eee"}}>
            <div style={{flexShrink:0}}>
              <div style={{display:"flex",flexDirection:"column",alignItems:"center"}}>
                <span style={{fontFamily:"'Segoe UI',Arial,sans-serif",fontSize:18,fontWeight:800,letterSpacing:4,color:"#2d3561",textTransform:"uppercase",lineHeight:1}}>NICASTRO SOLLER</span>
                <div style={{display:"flex",alignItems:"center",gap:8,marginTop:4}}>
                  <div style={{height:2,width:24,background:"#b02626"}}/>
                  <span style={{fontSize:10,letterSpacing:5,color:"#2d3561",textTransform:"uppercase",fontWeight:600}}>ADVOGADOS</span>
                  <div style={{height:2,width:24,background:"#b02626"}}/>
                </div>
              </div>
            </div>
            <div style={{width:1,height:44,background:"#eee",flexShrink:0}}/>
            <div>
              <div style={{fontSize:13,color:"#888",marginBottom:3}}>Ferramenta Jurídica Gratuita</div>
              <div style={{display:"flex",gap:14,flexWrap:"wrap"}}>
                <span style={{fontSize:12,color:"#b02626",fontWeight:600}}>📸 @nicastrosolleradvogados</span>
                <span style={{fontSize:12,color:"#b02626",fontWeight:600}}>👤 @marcellanicastrosoller</span>
              </div>
            </div>
          </div>
          {/* Título */}
          <div style={{display:"flex",alignItems:"center",gap:12}}>
            <div style={{width:4,height:36,background:"#b02626",borderRadius:2,flexShrink:0}}/>
            <div>
              <h1 style={{fontSize:20,fontWeight:800,color:"#1a1a1a",margin:0,lineHeight:1.2}}>⚖️ Calculadora de Prazos Judiciais</h1>
              <p style={{margin:"4px 0 0",fontSize:12,color:"#888"}}>CPC · CPP · CLT · Código Eleitoral — todos os prazos legais</p>
            </div>
          </div>
        </div>
      </div>

      <div style={{maxWidth:860,margin:"0 auto",padding:"20px 14px 40px"}}>

        {/* Modo */}
        <div style={{display:"flex",gap:8,marginBottom:16}}>
          {[["vencimento","📅 Calcular vencimento"],["restante","⏳ Dias restantes"]].map(([v,l])=>(
            <button key={v} onClick={()=>{setModo(v);setRes(null);}}
              style={{flex:1,padding:"11px 0",borderRadius:8,border:"2px solid",
                borderColor:modo===v?"#b02626":"#ddd",
                background:modo===v?"#b02626":"#fff",
                color:modo===v?"#fff":"#555",
                fontWeight:700,fontSize:14,cursor:"pointer",transition:".15s"}}>
              {l}
            </button>
          ))}
        </div>

        {/* Ramo */}
        <div style={{marginBottom:14}}>
          <div style={{fontSize:11,fontWeight:700,color:"#888",textTransform:"uppercase",letterSpacing:1,marginBottom:8}}>Ramo do Direito</div>
          <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
            {Object.keys(ramoLabels).map(r=>(
              <button key={r} onClick={()=>mudarRamo(r)}
                style={{padding:"8px 20px",borderRadius:6,border:"2px solid",
                  borderColor:ramo===r?ramoColors[r]:"#ddd",
                  background:ramo===r?ramoColors[r]:"#fff",
                  color:ramo===r?"#fff":"#444",
                  fontWeight:700,fontSize:13,cursor:"pointer",transition:".15s"}}>
                {ramoLabels[r]}
              </button>
            ))}
          </div>
        </div>

        {/* Card principal */}
        <div style={card}>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:14,marginBottom:14}}>
            <div>
              <label style={{fontSize:11,fontWeight:700,color:"#888",textTransform:"uppercase",letterSpacing:1,display:"block",marginBottom:6}}>Tribunal</label>
              <select value={tribunal.id} onChange={e=>setTribunal(tribunais[ramo].find(t=>t.id===e.target.value))} style={inp}>
                {tribunais[ramo].map(t=><option key={t.id} value={t.id}>{t.label}</option>)}
              </select>
            </div>
            <div>
              <label style={{fontSize:11,fontWeight:700,color:"#888",textTransform:"uppercase",letterSpacing:1,display:"block",marginBottom:6}}>
                {modo==="vencimento"?"Data do Ato / Publicação":"Data de Vencimento"}
              </label>
              <input type="date" value={modo==="vencimento"?dAto:dVenc}
                onChange={e=>modo==="vencimento"?setDAto(e.target.value):setDVenc(e.target.value)}
                style={inp}/>
            </div>
          </div>

          {modo==="vencimento"&&(
            <div style={{marginBottom:14}}>
              <label style={{fontSize:11,fontWeight:700,color:"#888",textTransform:"uppercase",letterSpacing:1,display:"block",marginBottom:6}}>Tipo de Prazo</label>
              <input placeholder="🔍 Buscar prazo..." value={busca} onChange={e=>setBusca(e.target.value)} style={{...inp,marginBottom:8}}/>
              <select size={5} value={prazo.label}
                onChange={e=>{const p=prazosConfig[ramo].find(x=>x.label===e.target.value);if(p)setPrazo(p);}}
                style={{...inp,minHeight:110,fontSize:13}}>
                {(lista||prazosConfig[ramo]).map(p=>(
                  <option key={p.label} value={p.label}>
                    {p.grupo?`[${p.grupo}] `:""}{p.label}{p.dias!==null?` — ${p.dias}d ${p.tipo==="uteis"?"úteis":"corridos"}`:""}
                  </option>
                ))}
              </select>
              {prazo&&prazo.dias!==null&&(
                <div style={{marginTop:8,padding:"10px 14px",background:"#fafafa",borderRadius:6,fontSize:13,color:"#333",borderLeft:`3px solid ${accent}`}}>
                  <strong style={{color:accent}}>{prazo.label}</strong>
                  <span style={{color:"#888",marginLeft:8}}>{prazo.dias} {prazo.tipo==="uteis"?"dias úteis":"dias corridos"}</span>
                </div>
              )}
            </div>
          )}

          {modo==="vencimento"&&prazo.dias===null&&(
            <div style={{display:"flex",gap:12,marginBottom:14}}>
              <div style={{flex:1}}>
                <label style={{fontSize:11,fontWeight:700,color:"#888",display:"block",marginBottom:6}}>Quantidade de dias</label>
                <input type="number" min={1} value={cDias} onChange={e=>setCDias(e.target.value)} style={inp}/>
              </div>
              <div style={{flex:1}}>
                <label style={{fontSize:11,fontWeight:700,color:"#888",display:"block",marginBottom:6}}>Tipo</label>
                <select value={cTipo} onChange={e=>setCTipo(e.target.value)} style={inp}>
                  <option value="uteis">Dias úteis</option>
                  <option value="corridos">Dias corridos</option>
                </select>
              </div>
            </div>
          )}

          <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:18}}>
            <input type="checkbox" id="rec" checked={recesso} onChange={e=>setRecesso(e.target.checked)} style={{width:16,height:16,accentColor:"#b02626"}}/>
            <label htmlFor="rec" style={{fontSize:12,color:"#666",cursor:"pointer"}}>
              Suspender prazos no recesso forense (20/dez–20/jan e julho) — CPC art. 220 / CLT art. 775-A / CPP art. 798-A
            </label>
          </div>

          <button onClick={calc}
            style={{width:"100%",padding:"13px 0",borderRadius:8,border:"none",
              background:"#b02626",color:"#fff",fontSize:15,fontWeight:800,cursor:"pointer",
              letterSpacing:.5,boxShadow:"0 4px 14px #b0262633",transition:".15s"}}>
            Calcular Prazo
          </button>
        </div>

        {/* Resultado */}
        {res&&(
          <div style={{...card,padding:0,overflow:"hidden"}}>
            {/* Status */}
            <div style={{background:sc,padding:"18px 24px",color:"#fff",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
              <div>
                <div style={{fontSize:11,opacity:.85,fontWeight:700,textTransform:"uppercase",letterSpacing:1}}>
                  {res.restam<0?"⚠️ PRAZO VENCIDO":res.restam===0?"🚨 VENCE HOJE":"✅ Prazo em aberto"}
                </div>
                <div style={{fontSize:28,fontWeight:900,marginTop:4}}>
                  {res.restam<0?`${Math.abs(res.restam)} dias atrás`:res.restam===0?"Hoje!":`${res.restam} dias restantes`}
                </div>
              </div>
              <div style={{textAlign:"right"}}>
                <div style={{fontSize:11,opacity:.8}}>Vencimento</div>
                <div style={{fontSize:15,fontWeight:700,marginTop:2}}>{fmt(res.vencimento)}</div>
              </div>
            </div>

            {/* Linha do tempo */}
            {res.modo==="vencimento"&&res.eventos&&res.eventos.length>0&&(
              <div style={{padding:20}}>
                <div style={{fontSize:11,fontWeight:700,color:"#888",marginBottom:12,textTransform:"uppercase",letterSpacing:1}}>
                  Linha do tempo — {res.qtd} {res.tipoPrazo==="uteis"?"dias úteis":"dias corridos"}
                </div>
                <div style={{display:"flex",flexWrap:"wrap",gap:5}}>
                  {res.eventos.map((ev,i)=>{
                    const isLast=i===res.eventos.length-1;
                    let bg="#f4f4f4",border="#ddd",text="#555";
                    if(ev.feriado){bg="#fff3f3";border="#f5c6c6";text="#8b0000";}
                    if(ev.recesso&&!ev.feriado){bg="#fff8f0";border="#f5d6a0";text="#7c4d00";}
                    if(ev.util&&ev.contado){bg:"#fff";border=accent;text=accent;bg="#fff5f5";}
                    if(ev.util&&ev.contado){bg="#fff5f5";border="#b02626";text="#b02626";}
                    if(isLast){bg=sc+"22";border=sc;text="#1a1a1a";}
                    return(
                      <div key={i} style={{minWidth:46,padding:"5px 7px",borderRadius:6,background:bg,border:`1.5px solid ${border}`,textAlign:"center"}}>
                        <div style={{fontSize:9,color:"#aaa"}}>{ev.data.toLocaleDateString("pt-BR",{weekday:"short"}).replace(".","").toUpperCase()}</div>
                        <div style={{fontSize:13,fontWeight:700,color:text}}>{ev.data.getDate().toString().padStart(2,"0")}</div>
                        {ev.contado&&<div style={{fontSize:8,color:"#b02626",fontWeight:700}}>D{ev.contado}</div>}
                        {ev.feriado&&<div style={{fontSize:8,color:"#b02626"}}>FER</div>}
                        {ev.recesso&&!ev.feriado&&<div style={{fontSize:8,color:"#7c4d00"}}>REC</div>}
                        {ev.prorrogado&&<div style={{fontSize:8,color:"#888"}}>PRO</div>}
                        {isLast&&!ev.contado&&<div style={{fontSize:8,color:sc,fontWeight:700}}>FIM</div>}
                      </div>
                    );
                  })}
                </div>
                <div style={{display:"flex",gap:16,marginTop:12,flexWrap:"wrap"}}>
                  {[["#b02626","Dia contado"],["#f5c6c6","Feriado"],["#f5d6a0","Recesso"],[sc,"Vencimento"]].map(([cor,label])=>(
                    <div key={label} style={{display:"flex",alignItems:"center",gap:5,fontSize:11,color:"#888"}}>
                      <div style={{width:10,height:10,borderRadius:2,background:cor,border:"1px solid #ddd"}}/>{label}
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Info */}
            <div style={{padding:"0 20px 18px"}}>
              <div style={{padding:"10px 14px",background:"#fafafa",borderRadius:6,fontSize:12,color:"#666",borderLeft:`3px solid ${accent}`}}>
                <strong style={{color:"#1a1a1a"}}>{tribunal.label}</strong> · UF: {tribunal.uf} ·{" "}
                {res.modo==="vencimento"?`${res.tipoPrazo==="uteis"?"Dias úteis (CPC art. 219)":"Dias corridos"}`:"Modo: dias restantes"}
                {res.modo==="vencimento"&&prazo?.label&&` · ${prazo.label}`}
              </div>
            </div>
          </div>
        )}

        {/* Rodapé */}
        <div style={{marginTop:28,textAlign:"center",borderTop:"1px solid #e0e0e0",paddingTop:20}}>
          <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:4}}>
            <span style={{fontFamily:"'Segoe UI',Arial",fontSize:13,fontWeight:800,letterSpacing:4,color:"#2d3561",textTransform:"uppercase"}}>NICASTRO SOLLER</span>
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <div style={{height:1.5,width:18,background:"#b02626"}}/>
              <span style={{fontSize:9,letterSpacing:4,color:"#2d3561",textTransform:"uppercase",fontWeight:600}}>ADVOGADOS</span>
              <div style={{height:1.5,width:18,background:"#b02626"}}/>
            </div>
            <div style={{fontSize:11,color:"#b02626",marginTop:4,fontWeight:600}}>
              @nicastrosolleradvogados · @marcellanicastrosoller
            </div>
            <div style={{fontSize:10,color:"#bbb",marginTop:4}}>
              Ferramenta jurídica gratuita · Uso exclusivamente informativo · Sempre confirme com a legislação vigente
            </div>
          </div>
        </div>

      </div>
    </div>
  );
}

ReactDOM.render(<App/>,document.getElementById('root'));
</script>
</body>
</html>
